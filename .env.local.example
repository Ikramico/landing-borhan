# Google Sheets Integration
# Step 1: Go to Google Cloud Console → Create a Service Account
# Step 2: Download the JSON key file
# Step 3: Copy values below from the JSON file

GOOGLE_SERVICE_ACCOUNT_EMAIL=your-service-account@your-project.iam.gserviceaccount.com
GOOGLE_PRIVATE_KEY="-----BEGIN RSA PRIVATE KEY-----\nYOUR_KEY_HERE\n-----END RSA PRIVATE KEY-----\n"
GOOGLE_SHEET_ID=your_google_sheet_id_here

# How to find your Sheet ID:
# Open your Google Sheet → look at the URL:
# https://docs.google.com/spreadsheets/d/THIS_IS_YOUR_SHEET_ID/edit
